---
import { getEntry } from "astro:content";

const entry = await getEntry("landingFeatures", "features");
const f = entry!.data;
---
<section class="section" id="fitur">
  <div class="container">
    <div class="section-header">
      <span class="section-label">{f.label}</span>
      <h2>{f.title}</h2>
      <p>{f.description}</p>
    </div>
    <div class="features-grid">
      {f.items.map((item) => (
        <div class="feature-card">
          {item.premium && <span class="premium-tag">PREMIUM</span>}
          <div class={`feature-icon${item.premium && item.iconType === "svg" ? " premium" : ""}`}>
            {item.iconType === "image" ? (
              <img src={item.icon} alt={item.title} loading="lazy" />
            ) : item.iconType === "svg" ? (
              <Fragment set:html={item.icon} />
            ) : (
              item.icon
            )}
          </div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
